{
  "openapi": "3.0.3",
  "info": {
    "title": "Bella Cucina Restaurant API",
    "description": "Dynamic API tools for Bella Cucina Restaurant. Static info (working hours, contact, policies, payment methods) is handled by the Knowledge Base.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://bella-cucina-restaurant-production.up.railway.app",
      "description": "Bella Cucina Live Server"
    }
  ],
  "paths": {
    "/menu": {
      "get": {
        "summary": "Get full menu with prices",
        "operationId": "getFullMenu",
        "description": "Returns the complete restaurant menu with all categories, items, prices, and dietary info. Use this when a customer asks about the menu, food options, prices, or specific dishes.",
        "tags": ["Menu"],
        "responses": {
          "200": {
            "description": "Full menu with categories and items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "restaurant": {
                      "type": "string",
                      "example": "Bella Cucina"
                    },
                    "categories": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string",
                            "example": "Main Courses"
                          },
                          "name_ar": {
                            "type": "string",
                            "example": "الأطباق الرئيسية"
                          },
                          "items": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "type": "integer",
                                  "example": 3
                                },
                                "name": {
                                  "type": "string",
                                  "example": "Margherita Pizza"
                                },
                                "name_ar": {
                                  "type": "string",
                                  "example": "بيتزا مارجريتا"
                                },
                                "description": {
                                  "type": "string",
                                  "example": "Classic pizza with fresh mozzarella, tomato sauce, and basil"
                                },
                                "price": {
                                  "type": "number",
                                  "example": 120
                                },
                                "currency": {
                                  "type": "string",
                                  "example": "EGP"
                                },
                                "is_vegetarian": {
                                  "type": "boolean"
                                },
                                "is_gluten_free": {
                                  "type": "boolean"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/offers": {
      "get": {
        "summary": "Get current offers and promotions",
        "operationId": "getCurrentOffers",
        "description": "Returns all currently active promotions, discounts, and special offers. Use this when a customer asks about deals, discounts, or current promotions.",
        "tags": ["Offers"],
        "responses": {
          "200": {
            "description": "List of active offers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": {
                      "type": "integer"
                    },
                    "offers": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "example": "offer_1"
                          },
                          "title": {
                            "type": "string",
                            "example": "Family Friday"
                          },
                          "title_ar": {
                            "type": "string",
                            "example": "جمعة العيلة"
                          },
                          "description": {
                            "type": "string",
                            "example": "20% off on all main courses every Friday"
                          },
                          "discount_percent": {
                            "type": "integer",
                            "example": 20
                          },
                          "valid_days": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "valid_until": {
                            "type": "string",
                            "format": "date"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/orders": {
      "post": {
        "summary": "Place a new food order",
        "operationId": "placeOrder",
        "description": "Places a new food order for delivery or pickup. Requires customer name, phone, items with quantities, and order type. Use this when a customer wants to order food.",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["customer_name", "phone", "items", "order_type"],
                "properties": {
                  "customer_name": {
                    "type": "string",
                    "example": "Ahmed Mohamed"
                  },
                  "phone": {
                    "type": "string",
                    "example": "+201012345678"
                  },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "item_id": {
                          "type": "integer",
                          "example": 3
                        },
                        "quantity": {
                          "type": "integer",
                          "example": 2
                        },
                        "special_instructions": {
                          "type": "string",
                          "example": "no onions"
                        }
                      }
                    }
                  },
                  "order_type": {
                    "type": "string",
                    "enum": ["delivery", "pickup"],
                    "example": "delivery"
                  },
                  "address": {
                    "type": "string",
                    "example": "15 Tahrir St, Cairo"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order placed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order_id": {
                      "type": "string",
                      "example": "ORD-2026-001"
                    },
                    "status": {
                      "type": "string",
                      "example": "received"
                    },
                    "total": {
                      "type": "number",
                      "example": 350
                    },
                    "estimated_delivery": {
                      "type": "string",
                      "example": "45 minutes"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "summary": "Track order status",
        "operationId": "getOrderStatus",
        "description": "Returns the current status and details of an existing order by order ID. Use this when a customer wants to track or check on their order.",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Order ID (e.g. ORD-2026-001)"
          }
        ],
        "responses": {
          "200": {
            "description": "Order details and current status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order_id": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string",
                      "enum": ["received", "preparing", "on_the_way", "delivered", "cancelled"]
                    },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "quantity": {
                            "type": "integer"
                          },
                          "price": {
                            "type": "number"
                          }
                        }
                      }
                    },
                    "total": {
                      "type": "number"
                    },
                    "estimated_delivery": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Order not found"
          }
        }
      }
    },
    "/reservations": {
      "post": {
        "summary": "Make a table reservation",
        "operationId": "createReservation",
        "description": "Creates a new table reservation. Requires customer name, phone, date, time, and number of guests. Use this when a customer wants to book a table.",
        "tags": ["Reservations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["customer_name", "phone", "date", "time", "guests"],
                "properties": {
                  "customer_name": {
                    "type": "string",
                    "example": "Sara Ali"
                  },
                  "phone": {
                    "type": "string",
                    "example": "+201098765432"
                  },
                  "date": {
                    "type": "string",
                    "format": "date",
                    "example": "2026-03-10"
                  },
                  "time": {
                    "type": "string",
                    "example": "19:00"
                  },
                  "guests": {
                    "type": "integer",
                    "example": 4
                  },
                  "special_requests": {
                    "type": "string",
                    "example": "window seat please"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reservation created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "reservation_id": {
                      "type": "string",
                      "example": "RES-2026-015"
                    },
                    "customer_name": {
                      "type": "string"
                    },
                    "date": {
                      "type": "string"
                    },
                    "time": {
                      "type": "string"
                    },
                    "guests": {
                      "type": "integer"
                    },
                    "status": {
                      "type": "string",
                      "example": "confirmed"
                    },
                    "table_number": {
                      "type": "integer",
                      "example": 7
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/delivery/check": {
      "post": {
        "summary": "Check delivery availability for an area",
        "operationId": "checkDeliveryArea",
        "description": "Checks if delivery is available for a specific area and returns the delivery fee, estimated time, and minimum order amount. Use this when a customer asks if you deliver to their area.",
        "tags": ["Delivery"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["area"],
                "properties": {
                  "area": {
                    "type": "string",
                    "example": "Zamalek"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Delivery availability and details for the area",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "available": {
                      "type": "boolean"
                    },
                    "area": {
                      "type": "string"
                    },
                    "delivery_fee": {
                      "type": "number",
                      "example": 25
                    },
                    "estimated_time": {
                      "type": "string",
                      "example": "30-45 minutes"
                    },
                    "minimum_order": {
                      "type": "number",
                      "example": 150
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/loyalty/{phone}": {
      "get": {
        "summary": "Check loyalty points balance",
        "operationId": "getLoyaltyPoints",
        "description": "Returns the loyalty points balance, tier level, and available rewards for a customer. Use this when a customer asks about their points or rewards.",
        "tags": ["Loyalty"],
        "parameters": [
          {
            "name": "phone",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Customer phone number"
          }
        ],
        "responses": {
          "200": {
            "description": "Loyalty account details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "phone": {
                      "type": "string"
                    },
                    "customer_name": {
                      "type": "string"
                    },
                    "points": {
                      "type": "integer",
                      "example": 450
                    },
                    "tier": {
                      "type": "string",
                      "enum": ["bronze", "silver", "gold"],
                      "example": "silver"
                    },
                    "available_rewards": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "reward_id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "points_required": {
                            "type": "integer"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Customer not found"
          }
        }
      }
    }
  }
}